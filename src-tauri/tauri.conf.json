{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "meu-app-tauri",
  "version": "0.1.0",
  "identifier": "com.gabriel.meu-app-tauri",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AmigoMec\u00e2nico",
        "width": 800,
        "height": 600,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://gbtrajano.github.io/mycontent/latest.json"
      ]
    }
  }
}