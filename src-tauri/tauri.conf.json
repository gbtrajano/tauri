{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AmigoMecanico",
  "version": "0.1.9",
  "identifier": "com.supplysistemas.amigomecanico",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AmigoMecânico",
        "width": 800,
        "height": 600,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Supply Sistemas",
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCNjQ1OUZENDkwQUJERDcKUldUWHZRcEovVmxrRy9PQjdnUEpaQ01OWEdUZmpodHFFTHJJZ1lNL1pwbUhBamJUZ3RRTUdkcUoK",
      "endpoints": [
        "https://gbtrajano.github.io/mycontent/latest.json"
      ]
    }
  }
}